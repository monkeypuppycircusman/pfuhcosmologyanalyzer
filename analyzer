<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>PFUH Analyzer — FITS Viewer</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:      #0d1117;
  --surface: #161b22;
  --panel:   #1c2128;
  --border:  #30363d;
  --border2: #484f58;
  --pi:      #79c0ff;
  --phi:     #ffa657;
  --tri:     #56d364;
  --m:       #d2a8ff;
  --text:    #c9d1d9;
  --muted:   #8b949e;
  --bright:  #f0f6fc;
}

body {
  font-family: ui-monospace, "SFMono-Regular", "Cascadia Code", monospace;
  font-size: 12px;
  background: var(--bg);
  color: var(--text);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  user-select: none;
}

/* ── TITLE BAR ─────────────────────────────────────── */
#titlebar {
  display: flex; align-items: center; gap: 10px;
  padding: 6px 14px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
#titlebar .app-title { font-weight: 700; font-size: 13px; color: var(--bright); }
#titlebar .app-sub   { font-size: 11px; color: var(--muted); }
#titlebar .spacer    { flex: 1; }
#titlebar .consts    { display: flex; gap: 16px; font-size: 10px; color: var(--muted); }
#titlebar .consts b  { color: var(--phi); }

/* ── WORKSPACE ─────────────────────────────────────── */
#workspace { display: flex; flex: 1; overflow: hidden; }

/* ── SIDEBAR ───────────────────────────────────────── */
#sidebar {
  width: 182px; flex-shrink: 0;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow-y: auto;
  padding: 10px 8px; gap: 4px;
}

.sec {
  font-size: 10px; color: var(--muted);
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 2px 0; border-bottom: 1px solid var(--border);
  margin-top: 6px;
}

.btn {
  display: block; width: 100%;
  padding: 6px 10px; margin-top: 3px;
  background: var(--panel);
  border: 1px solid var(--border); border-radius: 4px;
  color: var(--text);
  font-family: inherit; font-size: 11px;
  cursor: pointer; text-align: left;
  transition: border-color 0.1s, background 0.1s;
}
.btn:hover   { border-color: var(--border2); background: #21262d; }
.btn.primary { border-color: var(--pi);  color: var(--pi); }
.btn.primary:hover { background: rgba(121,192,255,0.07); }
.btn.success { border-color: var(--tri); color: var(--tri); }
.btn.success:hover { background: rgba(86,211,100,0.07); }
.btn.off     { opacity: 0.38; cursor: default; pointer-events: none; }

.radio-group { display: flex; flex-direction: column; gap: 3px; margin-top: 4px; }
.radio-opt {
  display: flex; align-items: center; gap: 7px;
  padding: 5px 8px;
  border: 1px solid var(--border); border-radius: 4px;
  cursor: pointer; font-size: 11px;
  transition: border-color 0.1s, background 0.1s;
}
.radio-opt:hover { border-color: var(--border2); background: #21262d; }
.radio-opt.on    { border-color: var(--pi); color: var(--pi); background: rgba(121,192,255,0.06); }
.rdot {
  width: 8px; height: 8px; border-radius: 50%;
  border: 1px solid var(--muted); flex-shrink: 0;
}
.radio-opt.on .rdot { background: var(--pi); border-color: var(--pi); }

#hduSelect {
  width: 100%; margin-top: 4px;
  background: var(--panel);
  border: 1px solid var(--border); border-radius: 4px;
  color: var(--text); font-family: inherit; font-size: 11px;
  padding: 5px 8px; cursor: pointer;
}
#hduSelect:disabled { opacity: 0.38; cursor: default; }

/* ── CANVAS AREA ───────────────────────────────────── */
#canvasWrap {
  flex: 1; position: relative; overflow: hidden;
  background: #090c10; cursor: crosshair;
}
#mainCanvas {
  position: absolute; top: 0; left: 0;
  transform-origin: top left;
  image-rendering: pixelated;
}
#dropZone {
  position: absolute; inset: 20px;
  border: 2px dashed var(--border2); border-radius: 8px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8px;
  pointer-events: none;
}
#dropZone.drag { border-color: var(--phi); }
#dropZone .dz-ico   { font-size: 38px; opacity: 0.22; }
#dropZone .dz-title { font-size: 13px; color: var(--muted); letter-spacing: 0.05em; }
#dropZone .dz-sub   { font-size: 10px; color: var(--border2); }
#hud-tl {
  position: absolute; top: 8px; left: 8px;
  font-size: 10px; color: rgba(121,192,255,0.5);
  letter-spacing: 0.05em; line-height: 1.9; pointer-events: none;
}
#hud-br {
  position: absolute; bottom: 8px; right: 10px;
  font-size: 10px; color: var(--muted); pointer-events: none;
}

/* ── RIGHT PANEL ───────────────────────────────────── */
#rightpanel {
  width: 204px; flex-shrink: 0;
  background: var(--surface);
  border-left: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow-y: auto;
  padding: 10px 8px; gap: 7px;
}
.metric {
  border: 1px solid var(--border); border-radius: 4px;
  padding: 7px 9px;
}
.metric .mlabel { font-size: 10px; color: var(--muted); letter-spacing: 0.07em; text-transform: uppercase; }
.metric .mval   { font-size: 18px; font-weight: 700; margin: 2px 0; }
.metric .msub   { font-size: 10px; color: var(--muted); }
.m-pi   .mval { color: var(--pi); }
.m-phi  .mval { color: var(--phi); }
.m-m    .mval { color: var(--m); }
.m-node .mval { color: var(--tri); }

#histCanvas { width: 100%; height: 68px; border: 1px solid var(--border); border-radius: 3px; display: block; }

.rpl { font-size: 10px; color: var(--muted); letter-spacing: 0.07em; text-transform: uppercase; margin-top: 2px; }

#nodeList {
  font-size: 10px; line-height: 1.85;
  max-height: 155px; overflow-y: auto;
  border: 1px solid var(--border); border-radius: 3px;
  padding: 5px 7px; color: var(--muted);
}
.nl-s { color: var(--text); }
.nl-d { color: var(--phi); }

#grammarSeq {
  font-size: 10px; color: var(--pi); word-break: break-all; line-height: 1.7;
  border: 1px solid var(--border); border-radius: 3px; padding: 5px 7px;
}

#ratioOut  { font-size: 11px; color: var(--muted); }
#phiHitOut { font-size: 11px; color: var(--muted); }

/* ── STATUS BAR ────────────────────────────────────── */
#statusbar {
  display: flex; align-items: center; gap: 10px;
  padding: 4px 12px;
  background: var(--surface); border-top: 1px solid var(--border);
  font-size: 10px; color: var(--muted); flex-shrink: 0;
}
#statusText { flex: 1; }
#progWrap { width: 120px; height: 3px; background: var(--panel); border-radius: 2px; overflow: hidden; }
#progBar  { height: 100%; background: linear-gradient(90deg, var(--pi), var(--phi)); width: 0; transition: width 0.25s; }

::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
</style>
</head>
<body>

<div id="titlebar">
  <span class="app-title">PFUH Analyzer</span>
